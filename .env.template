LOG_TO_FILE=0
RETENTION_DAYS=180
SENSOR_RETRY_DELAY_SECONDS=30

# Outdoor weather source
OUTDOOR_WEATHER_PROVIDER=open-meteo

# Preferred: exact coordinates for the location you want to sample.
OUTDOOR_WEATHER_LATITUDE=
OUTDOOR_WEATHER_LONGITUDE=

# Optional alternative: a postal code lookup if you do not want to store coordinates.
# For Germany, keep COUNTRY_CODE=DE.
OUTDOOR_WEATHER_POSTAL_CODE=
OUTDOOR_WEATHER_COUNTRY_CODE=DE

# How often to refresh outdoor data from the API.
# Open-Meteo current conditions are model-backed 15-minute data in Central Europe,
# so polling faster than 900 seconds only repeats the same value.
OUTDOOR_WEATHER_POLL_SECONDS=900

# Home Assistant integration
# HA_URL: base URL of your HA instance, e.g. http://homeassistant.local:8123
# HA_TOKEN: Long-Lived Access Token from your HA profile page
HA_URL=http://raspberrypi.local:8123
HA_TOKEN=your-long-lived-access-token-here